class Solution {
    public int scoreOfParentheses(String s) {
        Stack<Integer> stack = new Stack<>();
        stack.push(0); // base score
        
        for (char ch : s.toCharArray()) {
            if (ch == '(') {
                stack.push(0); // new frame
            } else {
                int top = stack.pop();
                int score = Math.max(2 * top, 1);
                stack.push(stack.pop() + score);
            }
        }
        
        return stack.pop();
    }
}
